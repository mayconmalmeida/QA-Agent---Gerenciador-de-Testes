# Escolha um provedor de IA (apenas um é necessário)

# Opção 1: OpenAI (pago) - https://platform.openai.com
OPENAI_API_KEY=sua_chave_openai_aqui

# Opção 2: Groq (gratuito) - https://console.groq.com
# GROQ_API_KEY=sua_chave_groq_aqui

# Opção 3: Ollama (gratuito/local) - https://ollama.com
# Não precisa de API key! Apenas instale e rode: ollama serve

# Opção 4: Anthropic Claude - https://console.anthropic.com
# ANTHROPIC_API_KEY=sua_chave_anthropic_aqui